# hireEVE — Environment Variables
# Copy to .env and fill in your values

# Database
DATABASE_URL=postgresql://eve:eve-local-dev@localhost:5432/hireeve

# Auth
JWT_SECRET=change-me-in-production

# OAuth Token Encryption (32-byte key, base64-encoded)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Required in production. In development it falls back to a deterministic dev key.
TOKEN_ENCRYPTION_KEY=

# AI — OpenRouter (free models available)
OPENROUTER_API_KEY=

# Stripe (optional — billing features)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
STRIPE_TEAM_PRICE_ID=

# Google OAuth (optional — Gmail/Calendar)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/google/callback

# Slack (optional)
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# Notion (optional)
NOTION_API_KEY=

# Frontend
FRONTEND_URL=http://localhost:8001
NEXT_PUBLIC_API_URL=http://localhost:3001
