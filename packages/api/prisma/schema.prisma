generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  passwordHash  String?
  name          String?
  role          UserRole       @default(USER)
  plan          Plan           @default(FREE)
  stripeId      String?        @unique
  emailVerified   Boolean    @default(false)
  verifyToken     String?
  verifyTokenExp  DateTime?
  resetToken      String?
  resetTokenExp   DateTime?
  agents          Agent[]
  testRuns      TestRun[]
  conversations Conversation[]
  tokens        UserToken[]
  tasks         Task[]
  notes         Note[]
  reminders     Reminder[]
  contacts       Contact[]
  calendarEvents CalendarEvent[]
  workspaceMembers   WorkspaceMember[]
  automationConfig   AutomationConfig?
  agentLogs          AgentLog[]
  notifications      Notification[]
  pushSubscriptions  PushSubscription[]
  memories           Memory[]
  tokenUsages        TokenUsage[]
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
}

enum UserRole {
  USER
  ADMIN
}

model Workspace {
  id        String            @id @default(uuid())
  name      String
  slug      String            @unique
  plan      Plan              @default(FREE)
  stripeId  String?           @unique
  members   WorkspaceMember[]
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
}

model WorkspaceMember {
  id          String        @id @default(uuid())
  userId      String
  user        User          @relation(fields: [userId], references: [id])
  workspaceId String
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  role        WorkspaceRole @default(MEMBER)
  createdAt   DateTime      @default(now())

  @@unique([userId, workspaceId])
}

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
}

model Agent {
  id        String    @id @default(uuid())
  name      String
  endpoint  String
  apiKey    String?
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  testRuns  TestRun[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model TestRun {
  id             String        @id @default(uuid())
  status         TestStatus    @default(QUEUED)
  score          Int?
  passCount      Int?
  failCount      Int?
  warnCount      Int?
  scenarioCount  Int           @default(100)
  agentId        String
  agent          Agent         @relation(fields: [agentId], references: [id])
  userId         String
  user           User          @relation(fields: [userId], references: [id])
  evaluations    Evaluation[]
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime      @default(now())
}

model Evaluation {
  id         String   @id @default(uuid())
  testRunId  String
  testRun    TestRun  @relation(fields: [testRunId], references: [id])
  scenario   String
  category   String
  verdict    Verdict
  reason     String?
  evidence   String?
  confidence Float?
  latencyMs  Int?
  createdAt  DateTime @default(now())
}

enum Plan {
  FREE
  PRO
  TEAM
  ENTERPRISE
}

enum TestStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
}

enum Verdict {
  PASS
  FAIL
  WARNING
}

model Conversation {
  id        String    @id @default(uuid())
  title     String?
  pinned    Boolean   @default(false)
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  messages  Message[]
  tokenUsages TokenUsage[]
  summaries   ConversationSummary[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           Role
  content        String
  createdAt      DateTime     @default(now())
}

enum Role {
  USER
  ASSISTANT
  SYSTEM
}

model UserToken {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  provider     String   // "google"
  accessToken  String
  refreshToken String?
  expiresAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, provider])
}

model Task {
  id          String     @id @default(uuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id])
  title       String
  description String?
  status      TaskStatus @default(TODO)
  priority    Priority   @default(MEDIUM)
  dueDate     DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Note {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  content   String
  category  String   @default("general")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Reminder {
  id          String         @id @default(uuid())
  userId      String
  user        User           @relation(fields: [userId], references: [id])
  title       String
  description String?
  remindAt    DateTime
  status      ReminderStatus @default(PENDING)
  createdAt   DateTime       @default(now())
}

enum ReminderStatus {
  PENDING
  SENT
  DISMISSED
}

model Contact {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  name      String
  email     String?
  phone     String?
  company   String?
  role      String?
  notes     String?
  tags      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CalendarEvent {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  title       String
  description String?
  startTime   DateTime
  endTime     DateTime
  location    String?
  meetingLink String?
  color       String?
  allDay      Boolean  @default(false)
  googleId    String?  @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AutomationConfig {
  id                    String   @id @default(uuid())
  userId                String   @unique
  user                  User     @relation(fields: [userId], references: [id])
  meetingAutoJoin       Boolean  @default(true)
  meetingAutoSummarize  Boolean  @default(true)
  emailAutoClassify     Boolean  @default(false)
  reminderAutoCheck     Boolean  @default(true)
  dailyBriefing        Boolean  @default(true)
  briefingTime          String   @default("09:00")
  downloadAutoOrganize  Boolean  @default(false)
  autonomousAgent       Boolean  @default(true)
  agentMode             String   @default("SUGGEST") // "SUGGEST" | "AUTO"
  agentIntervalMin      Int      @default(5)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model AgentLog {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String   // "notify" | "tool_call" | "skip" | "error"
  tool      String?  // tool name if action is tool_call
  summary   String   // what the agent decided/did
  reasoning String?  // LLM's reasoning
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String   // "reminder" | "calendar" | "email" | "task" | "meeting" | "briefing"
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
}

// Memory System — EVE remembers facts about each user across conversations
// Inspired by Claude Code's memdir/ persistent memory architecture
model Memory {
  id          String     @id @default(uuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id])
  type        MemoryType
  key         String     // short label, e.g. "preferred_language"
  content     String     // the remembered fact
  source      String?    // which conversation/context it came from
  confidence  Float      @default(1.0) // 0-1, lower for inferred facts
  lastUsedAt  DateTime   @default(now())
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@unique([userId, type, key])
  @@index([userId, type])
}

enum MemoryType {
  PREFERENCE   // user preferences (language, tone, schedule)
  FACT         // facts about the user (name, company, role)
  DECISION     // past decisions the user made
  CONTEXT      // ongoing project/work context
  FEEDBACK     // corrections or instructions from user
}

// Token Usage Tracking — per-conversation and per-user cost tracking
// Inspired by Claude Code's cost-tracker.ts
model TokenUsage {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  conversationId String?
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  model          String   // e.g. "openai/gpt-5.4-nano"
  promptTokens   Int
  completionTokens Int
  totalTokens    Int
  estimatedCost  Float    @default(0) // USD
  createdAt      DateTime @default(now())

  @@index([userId, createdAt])
  @@index([conversationId])
}

// Conversation Summary — compressed history for long conversations
// Inspired by Claude Code's services/compact/ auto-compaction
model ConversationSummary {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  summary        String       // compressed summary of messages
  messageCount   Int          // how many messages were summarized
  upToMessageId  String       // last message ID included in summary
  createdAt      DateTime     @default(now())

  @@index([conversationId])
}
