{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "EVE Desktop",
  "version": "0.1.0",
  "identifier": "com.hireeve.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "EVE",
        "width": 380,
        "height": 540,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "resizable": true,
        "minWidth": 320,
        "minHeight": 400,
        "x": 60,
        "y": 60
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "id": "eve-tray",
      "iconPath": "icons/32x32.png",
      "tooltip": "EVE — Your AI Employee"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {}
}
